# Add your API keys here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- n8n Automation Pipeline ---
# The backend populates jobs with automation tracking fields:
# - distribution_status: 'pending' -> 'distributed'
# - distributed_channels: array of channel names (e.g., ['telegram_premium'])
# 
# The n8n workflow queries MongoDB for jobs where:
# { "distribution_status": "pending", "is_active": true }
# 
# Jobs are marked as 'distributed' once posted to external platforms like Telegram.
