    {
      "parameters": {
        "jsCode": "const cutoff = Date.now() - 86400000;\nconst allJobs = $input.all().map(item => item.json);\n\nconst jobs = allJobs.filter(j => {\n  const jobDate = new Date(j.created_at).getTime();\n  return jobDate > cutoff && j.title && j.company;\n});\n\nif (jobs.length === 0) return [{ json: { total_jobs: 0 } }];\n\nconst entryLevel = jobs\n  .filter(j => (j.experience && j.experience.toLowerCase().includes('fresher')) || !j.experience)\n  .slice(0, 5);\n\nlet waText = \"*\ud83d\ude80 Today's Top 5 Handpicked Tech Jobs!* \\n\\n\";\nentryLevel.forEach(job => {\n  waText += `\ud83d\udcbc *${job.title}* at *${job.company}*\\n\ud83d\udccd ${job.location || 'Remote'}\\n\ud83d\udcb0 ${job.salary_status || 'Competitive CTC'}\\n\ud83d\udc49 Apply: ${job.apply_link}\\n\\n`;\n});\nwaText += \"\ud83d\udd25 *Join Premium for instant alerts:* skillhire.in/#pricing\";\n\nconst topJobsSummary = jobs.slice(0, 5).map(j => `- ${j.title} at ${j.company} (${j.location})`).join('\\n');\nconst bestJob = jobs[0];\n\nreturn [{\n  json: {\n    discord_text: waText,\n    ai_context: topJobsSummary,\n    total_jobs: jobs.length,\n    best_job_company: bestJob.company,\n    best_job_title: bestJob.title\n  }\n}];"
      },
