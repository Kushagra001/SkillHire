    {
      "parameters": {
        "jsCode": "const escapeHtml = (str) => (str ? String(str) : '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;');\n\nlet digestText = '<b>\ud83d\ude80 Premium Role Digest</b>\\n\\n';\nlet original_items = [];\n\nfor (const item of $input.all()) {\n  const j = item.json;\n  digestText += `<b>${escapeHtml(j.title)}</b> at <b>${escapeHtml(j.company)}</b>\\n`;\n  digestText += `\ud83d\udccd ${escapeHtml(j.location)} | \ud83d\udcb0 ${escapeHtml(j.salary_status || 'Not Disclosed')}\\n`;\n  digestText += `<a href=\"${escapeHtml(j.apply_link)}\">Apply Now</a>\\n\\n`;\n  \n  // Clone just the json to avoid circular issues\n  original_items.push({ ...j });\n}\n\ndigestText += `\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\u2501\\n<b>SkillHire Network:</b>\\n\ud83c\udf10 <a href=\"https://skillhire.in\">Website</a> | \ud83d\udcf8 <a href=\"https://www.instagram.com/skillhire.in\">Instagram</a> | \ud83d\udcbc <a href=\"https://www.linkedin.com/company/skillhirein\">LinkedIn</a>`;\n\nreturn [{ json: { message: digestText, channel_name: 'telegram_premium', _is_digest: true, original_items: original_items } }];\n"
      },
