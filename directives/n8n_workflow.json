      "parameters": {
        "jsCode": "\nlet premiumJobs = [];\nlet freeJobs = [];\n\n// Separate the items into two arrays based on channel\nfor (const item of $input.all()) {\n  if (item.json.channel_name === 'telegram_premium') {\n    premiumJobs.push(item);\n  } else {\n    freeJobs.push(item);\n  }\n}\n\nlet result = [];\n\n// Read 20 Premium, then 30 Free, iteratively until empty\nwhile (premiumJobs.length > 0 || freeJobs.length > 0) {\n  let pBatch = premiumJobs.splice(0, 20);\n  let fBatch = freeJobs.splice(0, 30);\n  result = result.concat(pBatch);\n  result = result.concat(fBatch);\n}\n\nreturn result;\n"
